{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "lib": ["esnext", "dom"],
    "module": "commonjs",
    "moduleResolution": "Node",
    "noUnusedLocals": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "es2021",
    "useUnknownInCatchVariables": false
  }
}
